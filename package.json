{
  "name": "operations-dashboard",
  "version": "1.1.0",
  "description": "Unified operations dashboard for Digital1010",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test:smoke": "bash scripts/smoke-v1.sh",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "restart:pm2": "pm2 restart operations-dashboard",
    "stop:pm2": "pm2 stop operations-dashboard",
    "test:smoke:intake": "bash scripts/smoke-intake-v2.sh",
    "intake:slack": "bash scripts/intake-slack-project.sh",
    "intake:gmail": "bash scripts/intake-gmail-task.sh",
    "intake:gmail:backfill": "bash scripts/backfill-gmail-2weeks.sh",
    "intake:gmail:backfill:cron:run": "bash scripts/run-joan-backfill-cron.sh",
    "intake:gmail:backfill:cron:install": "bash scripts/install-joan-backfill-cron.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "ws": "^8.13.0"
  }
}
