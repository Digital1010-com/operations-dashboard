      "comments": [],
      "category": "Marketing",
      "notes": "Complete CMO-level cold outreach strategy with 6 documents (71K words). Quality-first approach targeting 10-15 hand-picked prospects daily. Includes 3 ICPs (Healthcare, Facilities, B2B Services), 7 insight-led email templates, Apollo targeting, tracking system, and HighLevel CRM integration.",
      "rationale": "Need to fill pipeline with qualified leads. Mass email doesn't work—insight-led, research-based outreach targets high-value prospects with personalized messaging.",
      "risks": [
        {
          "severity": "low",
          "description": "Reply rate may be lower than 10% target initially",
          "mitigation": "Pilot phase allows template iteration. Weekly optimization based on response data."
        }
      ],
      "nextActions": [
        "Setup Apollo filters (30 min)",
        "Create HighLevel pipeline (30 min)",
        "Setup Google Sheets tracker (30 min)",
        "Check email deliverability (SPF/DKIM/DMARC)",
        "Launch Monday or post-Vegas (Michael decides)"
      ],
      "dependencies": [],
