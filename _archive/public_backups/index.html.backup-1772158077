        </div>

        <div class="sidebar-section">
          <div class="sidebar-title">🤖 Agents</div>
          <div id="agentsGrid">
            <!-- Agents populated by JS -->
          </div>
        </div>

        <div class="sidebar-section">
          <div class="sidebar-title">📝 Daily Logs</div>
          <div id="dailyLogs" style="font-size: 12px; max-height: 200px; overflow-y: auto;">
            <!-- Daily logs populated by JS -->
          </div>
        </div>
      </div>

      <!-- Center - Project Tiles with Tabs -->
      <div class="center-content">
        <!-- Tabs for Projects/Calendar View -->
        <div class="view-tabs" style="display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 2px solid rgba(0, 0, 0, 0.05); padding-bottom: 12px;">
          <button class="view-tab active" data-view="projects" onclick="switchView('projects')" style="flex: 1; padding: 12px; background: var(--accent-blue); color: white; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;">
            🎯 Projects View
          </button>
          <button class="view-tab" data-view="calendar" onclick="switchView('calendar')" style="flex: 1; padding: 12px; background: rgba(0, 0, 0, 0.05); color: var(--text-primary); border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;">
            📅 Calendar View
          </button>
        </div>

        <!-- Projects View (Default) -->
        <div id="projectsView" class="view-content active">
          <div id="projectsContainer">
            <!-- Projects will be rendered here -->
          </div>
        </div>

        <!-- Calendar View -->
        <div id="calendarView" class="view-content" style="display: none;">
          <div style="margin-bottom: 20px; display: flex; gap: 12px; align-items: center;">
            <button class="btn" onclick="calendarPrev()" style="padding: 8px 16px; background: rgba(0, 0, 0, 0.05); border: none; border-radius: 8px; cursor: pointer;">← Prev</button>
            <button class="btn" onclick="calendarToday()" style="padding: 8px 16px; background: var(--accent-blue); color: white; border: none; border-radius: 8px; cursor: pointer;">Today</button>
            <button class="btn" onclick="calendarNext()" style="padding: 8px 16px; background: rgba(0, 0, 0, 0.05); border: none; border-radius: 8px; cursor: pointer;">Next →</button>
            <span id="calendarTitle" style="flex: 1; text-align: center; font-weight: 600; font-size: 16px;"></span>
            <select id="calendarViewSelect" onchange="changeCalendarView(this.value)" style="padding: 8px 16px; background: white; border: 1px solid rgba(0, 0, 0, 0.1); border-radius: 8px; font-size: 14px;">
              <option value="month">Month</option>
              <option value="week">Week</option>
              <option value="day">Day</option>
            </select>
          </div>
          <div id="calendarContainer" style="height: 600px; border-radius: 12px; overflow: hidden;"></div>
          
          <!-- Calendar Legend -->
          <div style="margin-top: 20px; display: flex; gap: 16px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-secondary);">
              <div style="width: 12px; height: 12px; border-radius: 3px; background: #ef4444;"></div>
              <span>P0 - Critical</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-secondary);">
              <div style="width: 12px; height: 12px; border-radius: 3px; background: #f59e0b;"></div>
              <span>P1 - High</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-secondary);">
              <div style="width: 12px; height: 12px; border-radius: 3px; background: #3b82f6;"></div>
              <span>P2 - Medium</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-secondary);">
              <div style="width: 12px; height: 12px; border-radius: 3px; background: #10b981;"></div>
              <span>Completed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Sidebar - Detail View -->
      <div class="right-sidebar empty" id="detailPanel">
        <div>👈 Select a project to view details</div>
      </div>
    </div>
  </div>

  <!-- New Task Modal -->
  <div class="modal-overlay" id="newTaskModal">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title">Create New Task</div>
        <button class="modal-close" onclick="closeNewTaskModal()">×</button>
      </div>
      <form id="newTaskForm" onsubmit="createNewTask(event)">
        <div class="form-group">
          <label class="form-label">Task Name</label>
          <input type="text" class="form-input" id="taskName" required>
        </div>
        <div class="form-group">
          <label class="form-label">Client</label>
          <select class="form-select" id="taskClient" required>
            <option value="">Select Client</option>
            <!-- Populated by JS -->
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" id="taskCategory" required>
            <!-- Populated by JS -->
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Owner</label>
          <select class="form-select" id="taskOwner" required>
            <option value="Otto">Otto</option>
            <option value="Saad">Saad</option>
            <option value="Mo">Mo</option>
            <option value="Michael">Michael</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Priority</label>
          <select class="form-select" id="taskPriority" required>
            <option value="P0">P0 - Critical</option>
            <option value="P1" selected>P1 - High</option>
            <option value="P2">P2 - Normal</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea class="form-textarea" id="taskDescription"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Create Task</button>
      </form>
    </div>
  </div>

  <!-- Manage Clients Modal -->
  <div class="modal-overlay" id="manageClientsModal" onclick="if(event.target === this) closeManageClientsModal()">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title">Manage Clients</div>
        <button class="modal-close" onclick="closeManageClientsModal()">×</button>
      </div>

      <div style="margin-bottom: 24px;">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px;">Add New Client</div>
        <form id="addClientForm" onsubmit="addClient(event)">
          <div class="form-group">
            <input type="text" class="form-input" id="newClientName" placeholder="Client name (e.g., The Facilities Group)" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">+ Add Client</button>
        </form>
      </div>

      <div style="border-top: 1px solid rgba(0, 0, 0, 0.1); padding-top: 20px;">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px;">Current Clients</div>
        <div id="clientsList" style="max-height: 300px; overflow-y: auto;">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Manage Categories Modal -->
  <div class="modal-overlay" id="manageCategoriesModal" onclick="if(event.target === this) closeManageCategoriesModal()">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title">Manage Categories</div>
        <button class="modal-close" onclick="closeManageCategoriesModal()">×</button>
      </div>

      <div style="margin-bottom: 24px;">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px;">Add New Category</div>
        <form id="addCategoryForm" onsubmit="addCategory(event)">
          <div class="form-group">
            <input type="text" class="form-input" id="newCategoryName" placeholder="Category name (e.g., Sales)" required>
          </div>
          <div class="form-group">
            <input type="text" class="form-input" id="newCategoryEmoji" placeholder="Emoji (e.g., 💰)" maxlength="2" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">+ Add Category</button>
        </form>
      </div>

      <div style="border-top: 1px solid rgba(0, 0, 0, 0.1); padding-top: 20px;">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px;">Current Categories</div>
        <div id="categoriesList" style="max-height: 300px; overflow-y: auto;">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <script src="app.js?v=1772134801"></script>
<!-- Design Partner Feedback Form -->
<div id="feedback" style="
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  border-radius: 20px;
  border: 1px solid var(--glass-border);
  box-shadow: var(--shadow);
  padding: 30px;
  margin: 40px auto;
  max-width: 800px;
  display: none;
">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h3 style="font-size: 20px; font-weight: 600;">💬 Design Partner Feedback</h3>
    <button onclick="document.getElementById('feedback').style.display='none'" style="
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 24px;
      cursor: pointer;
      padding: 0;
    ">×</button>
  </div>
  
  <p style="color: var(--text-secondary); margin-bottom: 24px;">
    Your feedback shapes Mission Control. What would make this dashboard indispensable for your agency?
  </p>
  
  <form id="feedbackForm" style="display: grid; gap: 20px;">
    <div>
      <label style="display: block; margin-bottom: 8px; font-weight: 500;">What's your biggest agency operations pain point?</label>
      <textarea name="pain_point" style="
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
        font-family: inherit;
        resize: vertical;
        min-height: 100px;
      " placeholder="E.g., client reporting takes 10+ hours per month..."></textarea>
    </div>
    
    <div>
      <label style="display: block; margin-bottom: 8px; font-weight: 500;">What feature would be most valuable to you?</label>
      <select name="feature_priority" style="
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
        font-family: inherit;
      ">
        <option value="">Select the most important feature...</option>
        <option value="client_reporting">Automated Client Reporting</option>
        <option value="project_management">AI Project Management</option>
        <option value="team_coordination">Team Coordination & Delegation</option>
        <option value="financial_tracking">Profitability & Financial Tracking</option>
        <option value="content_automation">Content Creation Automation</option>
      </select>
    </div>
    
    <div>
      <label style="display: block; margin-bottom: 8px; font-weight: 500;">What would you pay monthly for this solution?</label>
      <div style="display: flex; gap: 12px;">
        <label style="display: flex; align-items: center; gap: 8px;">
          <input type="radio" name="price_point" value="99">
          $99/mo
        </label>
        <label style="display: flex; align-items: center; gap: 8px;">
          <input type="radio" name="price_point" value="249">
          $249/mo
        </label>
        <label style="display: flex; align-items: center; gap: 8px;">
          <input type="radio" name="price_point" value="499">
          $499/mo
        </label>
        <label style="display: flex; align-items: center; gap: 8px;">
          <input type="radio" name="price_point" value="999">
          $999/mo
        </label>
      </div>
    </div>
    
    <div>
      <label style="display: block; margin-bottom: 8px; font-weight: 500;">Email for follow-up (optional)</label>
      <input type="email" name="email" style="
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
        font-family: inherit;
      " placeholder="you@youragency.com">
    </div>
    
    <button type="submit" style="
      background: linear-gradient(135deg, #007aff 0%, #5856d6 100%);
      color: white;
      border: none;
      padding: 14px 28px;
      border-radius: 16px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s ease;
    " onmouseover="this.style.transform='translateY(-2px)';" 
       onmouseout="this.style.transform='translateY(0)';">
      Submit Feedback
    </button>
  </form>
  
  <div id="feedbackThankYou" style="display: none; text-align: center; padding: 40px;">
    <div style="font-size: 48px; margin-bottom: 16px;">🎉</div>
    <h3 style="font-size: 24px; font-weight: 600; margin-bottom: 12px;">Thank You!</h3>
    <p style="color: var(--text-secondary);">
      Your feedback has been submitted. We'll review it and may reach out for a follow-up conversation.
    </p>
  </div>
</div>

<script>
// Feedback form handling
document.addEventListener('DOMContentLoaded', function() {
  const feedbackForm = document.getElementById('feedbackForm');
  const feedbackThankYou = document.getElementById('feedbackThankYou');
  
  // Make feedback link work
  document.querySelector('a[href="#feedback"]').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('feedback').style.display = 'block';
    document.getElementById('feedback').scrollIntoView({ behavior: 'smooth' });
  });
  
  // Handle form submission
  feedbackForm.addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Collect form data
    const formData = new FormData(feedbackForm);
    const data = Object.fromEntries(formData);
    
    // Log to console (in real app, send to server)
    console.log('Design Partner Feedback:', data);
    
    // Show thank you message
    feedbackForm.style.display = 'none';
    feedbackThankYou.style.display = 'block';
    
    // Optional: Send to server
    // fetch('/api/feedback', { method: 'POST', body: JSON.stringify(data) })
  });
});
</script>

</body>
</html>
